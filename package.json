{
  "name": "src",
  "version": "0.0.0",
  "private": true,
  "description": "Public-safe Klaudia CLI manifest for the INDUBITABLY.AI fork.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "exports": {
    "./*": "./src/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node ./scripts/run-bun.mjs test",
    "test:no-env": "bash ./scripts/test-no-env.sh",
    "cli:source": "bash ./scripts/cli-from-source.sh",
    "test:watch": "node ./scripts/run-bun.mjs test --watch",
    "test:coverage": "node -e \"require('node:fs').rmSync('.coverage/bun', { recursive: true, force: true })\" && node ./scripts/run-bun.mjs test --coverage --coverage-reporter=lcov --coverage-dir=.coverage/bun && node ./scripts/summarize-coverage.mjs .coverage/bun/lcov.info",
    "test:structural": "node ./scripts/verify-harness.mjs && node ./scripts/verify-branding.mjs",
    "typecheck": "./node_modules/.bin/tsc --noEmit -p tsconfig.harness.json",
    "verify:openai-interactive": "node ./scripts/verify-openai-interactive.mjs",
    "verify:openai-transport": "node ./scripts/run-bun.mjs test test/provider/providerSession.test.ts test/provider/providerRegistry.test.ts test/provider/openaiAuthManager.test.ts test/provider/openaiModelCatalog.test.ts test/provider/openaiTransport.test.ts test/provider/openaiResponsesRequest.test.ts test/provider/openaiResponsesStream.test.ts test/runtime/openaiAuthStatus.test.ts test/runtime/openaiModelPicker.test.ts test/runtime/openaiQuerySmoke.test.ts",
    "verify:openai-live": "node ./scripts/verify-openai-live.mjs",
    "verify:openai-live-interactive": "node ./scripts/verify-openai-live-interactive.mjs",
    "verify:runtime": "node ./scripts/verify-runtime.mjs",
    "verify:harness": "node ./scripts/verify-harness.mjs && node ./scripts/verify-branding.mjs && ./node_modules/.bin/tsc --noEmit -p tsconfig.harness.json && node ./scripts/run-bun.mjs test && node ./scripts/verify-runtime.mjs",
    "verify:install": "npm install --ignore-scripts --package-lock-only --no-audit --no-fund --dry-run",
    "verify:supply-chain": "node ./scripts/verify-supply-chain.mjs",
    "smoke:stubs": "node ./scripts/smoke-stubs.mjs"
  },
